############################################################
# FlashVerse DeFiHub Deployment Environment Variables
# ---------------------------------------------------------
# This file defines the required environment variables
# for deploying and testing the DeFiHub contracts using Foundry.
# DO NOT commit your real private keys. Use .env.local for secrets.
############################################################

# PRIVATE_KEY: Your deployer private key in hex format (recommended for security).
# Used by Forge scripts to broadcast transactions.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- TREASURY_VAULT SPECIFIC VARIABLES ---
# TREASURY_INITIAL_FEE: Initial withdrawal fee for TreasuryVault (in basis points, max 1000).
# Example: 50 = 0.5% fee
TREASURY_INITIAL_FEE=50

# --- TOKEN & ADAPTER VARIABLES ---
# STAKING_TOKEN: Optional. Address of an existing ERC20 token to use for staking.
STAKING_TOKEN=

# REWARD_TOKEN: Optional. Address of an existing ERC20 token to use as rewards.
REWARD_TOKEN=

# DEX_ADAPTER: Optional. Address of an existing DEX adapter contract.
DEX_ADAPTER=

# LENDING_ADAPTER: Optional. Address of an existing Lending adapter contract.
LENDING_ADAPTER=

# --- RATE VARIABLES ---
# REWARD_RATE: The reward rate for staking (default is 1e18)
# This value defines the amount of reward token per staked token per second.
REWARD_RATE=1000000000000000000

# --- NETWORK VARIABLES ---
# RPC_URL: RPC endpoint for the network you want to deploy to
RPC_URL=http://127.0.0.1:8545